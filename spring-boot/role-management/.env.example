# Copy this file to .env and fill in real values before running `docker compose up`.

# Postgres
POSTGRES_DB=roleManagement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# JWT signing secret - use a long random string
JWT_SECRET=changeme

# Email verification - set to true only if MAIL_* below point to a real SMTP server
EMAIL_VERIFICATION_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
