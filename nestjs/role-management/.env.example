# Copy this file to .env and fill in real values before running the app
# or `docker compose up`. DB_HOST/REDIS_HOST below are for running the app
# directly on your host machine - docker-compose overrides both to the
# container service names (postgres/redis) automatically.

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=roleManagement

JWT_SECRET=changeme

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Email - set EMAIL_ENABLED=true only if the SMTP_* values below point to a real server
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
